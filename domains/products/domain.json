    "rule_taxonomy": "rule_taxonomy.json",
    "value_aliases": "value_aliases.json",
    "answer_templates": "answer_templates.json",
    "golden_cases": "golden_cases.json",
    "top_result_mapping": "top_result_mapping.yaml"
  },
  "execution": {
    "rank_field_id": null,
    "tuition_field_id": "price_usd",
    "projectable_required_field_ids": ["price_usd"],
    "numeric_helper_fields": [
      {"name": "__price_num", "field_id": "price_usd"},
      {"name": "__rating_num", "field_id": "rating", "optional": true},
      {"name": "__product_id_num", "field_id": "product_id", "optional": true}
    ],
    "sort_policy": [

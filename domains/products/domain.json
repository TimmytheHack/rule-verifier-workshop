      {"helper": "__product_id_num", "label_field_id": "product_id", "direction": "ASC", "nulls": "LAST", "optional": true}
    ],
    "row_number_output_key": "source_row_number",
    "row_number_offset": 1,
    "output_fields": [
      {"output_key": "product_id", "field_id": "product_id", "transform": "clean"},
      {"output_key": "product_name", "field_id": "product_name", "transform": "text"},
      {"output_key": "category", "field_id": "category", "transform": "text"},
      {"output_key": "price_usd", "field_id": "price_usd", "transform": "number", "helper": "__price_num"},
      {"output_key": "rating", "field_id": "rating", "transform": "number", "helper": "__rating_num"},
      {"output_key": "stock_count", "field_id": "stock_count", "transform": "int"},
      {"output_key": "brand", "field_id": "brand", "transform": "text"},
      {"output_key": "description", "field_id": "description", "transform": "text"}
    ],
    "static_output_fields": {}
  },
  "workbench": {
    "slot_labels": {
      "preferences.categories": "商品类别",

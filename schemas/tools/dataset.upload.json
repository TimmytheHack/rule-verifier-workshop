{
  "name": "dataset.upload",
  "description": "上传 CSV/Excel 到托管数据目录，生成路径安全 dataset_id 和 source_fingerprint。",
  "llm_safe": false,
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "filename": {"type": "string", "minLength": 1},
      "content_base64": {"type": "string"},
      "dataset_id": {"type": "string"},
      "sheet_name": {"type": "string"}
    },
    "required": ["filename", "content_base64"]
  },
  "output_schema": {
    "type": "object",
    "required": ["dataset_id", "status", "source_fingerprint"],
    "properties": {
      "dataset_id": {"type": "string"},
      "status": {"type": "string"},
      "source_fingerprint": {"type": "string"},
      "warnings": {"type": "array"}
    },
    "additionalProperties": true
  },
  "permission_scope": "dataset_write",
  "side_effects": ["writes uploaded source file", "writes dataset metadata"],
  "required_domain_status": "none",
  "executes_sql": false,
  "writes_files": true,
  "security_notes": [
    "dataset_id must be path safe.",
    "Uploaded files cannot overwrite built-in domains.",
    "This tool is not LLM-safe because it can write files.",
    "Tool upload accepts base64 content only; server-side source_path reads are disabled."
  ],
  "status_enum": ["uploaded", "blocked", "error"],
  "examples": [
    {
      "request": {"filename": "admissions.xlsx", "content_base64": "base64..."},
      "response": {"dataset_id": "ds_example", "status": "uploaded", "source_fingerprint": "sha256..."}
    }
  ]
}
